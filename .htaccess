RewriteEngine On

# Block direct web access to the Git metadata folder (when the repo is cloned
# into the web root via cPanel Git Version Control).
RewriteRule (^|/)\.git(/|$) - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/convert-to-pdf$ convert.php [L,QSA]
RewriteRule ^api/upload-file$ upload.php [L,QSA]
RewriteRule ^api/delete-file$ delete.php [L,QSA]
RewriteRule ^api/restore-file$ restore.php [L,QSA]
RewriteRule ^api/load-state$ api.php?action=load [L,QSA]
RewriteRule ^api/save-state$ api.php?action=save [L,QSA]
RewriteRule ^api/auth-info$ api.php?action=authinfo [L,QSA]
RewriteRule ^api/set-pin$ api.php?action=setpin [L,QSA]

# Deny direct web access to the data store, the sync secret, error logs,
# PHP config, and local-dev-only files
<FilesMatch "(database\.sqlite|database\.json|sync_secret\.php|sync_errors\.log|\.user\.ini|\.gitignore|server\.py|server\.ps1|DEPLOY\.md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent Apache from limiting request body size (large base64 uploads)
LimitRequestBody 0

# Always revalidate HTML/JS/CSS so a Git pull / deploy takes effect immediately
# (avoids the browser running a stale cached app.js after an update).
<IfModule mod_headers.c>
    <FilesMatch "\.(html|js|css)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
