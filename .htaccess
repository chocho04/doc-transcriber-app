RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/convert-doc$ convert.php [L,QSA]
RewriteRule ^api/convert-rtf$ convert.php [L,QSA]
RewriteRule ^api/convert-xls$ convert.php [L,QSA]
RewriteRule ^api/convert-to-pdf$ convert.php [L,QSA]
RewriteRule ^api/load-state$ api.php?action=load [L,QSA]
RewriteRule ^api/save-state$ api.php?action=save [L,QSA]
RewriteRule ^api/upload-file$ upload.php [L,QSA]
RewriteRule ^api/delete-file$ delete.php [L,QSA]

# Deny direct web access to SQLite, JSON database files, and error logs
<FilesMatch "(database\.sqlite|database\.json|sync_errors\.log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent Apache from limiting request body size
LimitRequestBody 0
